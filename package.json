{
  "name": "wacrm",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable CRM template for WhatsApp built on Next.js and Supabase — shared inbox, contacts, sales pipelines, broadcasts, and no-code automations.",
  "license": "MIT",
  "author": "Arnas Donauskas",
  "homepage": "https://wacrm.tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArnasDon/wacrm.git"
  },
  "bugs": {
    "url": "https://github.com/ArnasDon/wacrm/issues"
  },
  "keywords": [
    "crm",
    "whatsapp",
    "whatsapp-business-api",
    "nextjs",
    "supabase",
    "automation",
    "broadcast",
    "self-hosted",
    "template"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:mobile": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mobile:icons": "node scripts/generate-android-icons.mjs",
    "mobile:prepare": "node scripts/prepare-mobile-shell.mjs",
    "mobile:add-android": "npx cap add android",
    "mobile:sync": "npm run mobile:prepare && npx cap sync android",
    "mobile:open": "npx cap open android",
    "mobile:apk:local": "npm run mobile:icons && npm run mobile:sync && node scripts/android-build.mjs debug",
    "mobile:apk:debug": "npm run mobile:sync && node scripts/android-build.mjs debug",
    "mobile:apk:release": "npm run mobile:sync && node scripts/android-build.mjs release"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.2",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@capacitor/android": "^5.7.0",
    "@capacitor/cli": "^5.7.0",
    "@capacitor/core": "^5.7.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
